{
  "manifest_version": 3,
  "name": "My Lenses Notify",
  "version": "1.3.5",
  "description": "Watch My Lenses submissions and email you when status leaves Processing / In Review. Keep Chrome awake while watching.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "power",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://my-lenses.snapchat.com/*",
    "https://formsubmit.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "My Lenses Notify",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/soft-click.wav"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://my-lenses.snapchat.com/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
